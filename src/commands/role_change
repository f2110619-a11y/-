import { SlashCommandBuilder, PermissionFlagsBits } from 'discord.js';
import { getColor } from '../../config/bot.js';
import { successEmbed, errorEmbed } from '../../utils/embeds.js';
import { logger } from '../../utils/logger.js';
import { handleInteractionError, createError, ErrorTypes } from '../../utils/errorHandler.js';
import { InteractionHelper } from '../../utils/interactionHelper.js';

// ⚠️ ВАЖНО: Укажите ID канала для логирования выдачи ролей
// Можно взять из переменной окружения или из botConfig
const ROLE_LOG_CHANNEL_ID = process.env.ROLE_LOG_CHANNEL_ID || null;

export default {
    data: new SlashCommandBuilder()
        .setName('роли')
        .setDescription('🔧 Управление ролями пользователей')
        .setDefaultMemberPermissions(PermissionFlagsBits.ManageRoles)
        .addSubcommand(subcommand =>
            subcommand
                .setName('выдать')
                .setDescription('Выдать роль пользователю')
                .addUserOption(option =>
                    option.setName('пользователь')
                        .setDescription('Пользователь, которому выдать роль')
                        .setRequired(true)
                )
                .addRoleOption(option =>
                    option.setName('роль')
                        .setDescription('Роль для выдачи')
                        .setRequired(true)
                )
                .addStringOption(option =>
                    option.setName('причина')
                        .setDescription('Причина выдачи роли')
                        .setRequired(false)
                )
        )
        .addSubcommand(subcommand =>
            subcommand
                .setName('снять')
                .setDescription('Снять роль с пользователя')
                .addUserOption(option =>
                    option.setName('пользователь')
                        .setDescription('Пользователь, у которого снять роль')
                        .setRequired(true)
                )
                .addRoleOption(option =>
                    option.setName('роль')
                        .setDescription('Роль для снятия')
                        .setRequired(true)
                )
                .addStringOption(option =>
                    option.setName('причина')
                        .setDescription('Причина снятия роли')
                        .setRequired(false)
                )
        )
        .addSubcommand(subcommand =>
            subcommand
                .setName('список')
                .setDescription('Показать все роли пользователя')
                .addUserOption(option =>
                    option.setName('пользователь')
                        .setDescription('Пользователь для просмотра')
                        .setRequired(true)
                )
        ),

    async execute(interaction) {
        const subcommand = interaction.options.getSubcommand();

        try {
            // Отложенный ответ для долгих операций
            await InteractionHelper.safeDefer(interaction, { ephemeral: subcommand === 'список' ? false : true });

            switch (subcommand) {
                case 'выдать':
                    await handleAddRole(interaction);
                    break;
                case 'снять':
                    await handleRemoveRole(interaction);
                    break;
                case 'список':
                    await handleListRoles(interaction);
                    break;
            }
        } catch (error) {
            await handleInteractionError(interaction, error, {
                type: 'command',
                commandName: 'роли',
                subcommand: subcommand
            });
        }
    }
};

// ─────────────────────────────────────────────────────────────────────────────
// ВЫДАЧА РОЛИ
// ─────────────────────────────────────────────────────────────────────────────

async function handleAddRole(interaction) {
    const targetUser = interaction.options.getUser('пользователь');
    const role = interaction.options.getRole('роль');
    const reason = interaction.options.getString('причина') || 'Не указана';
    
    // Получаем участников для проверки иерархии
    const targetMember = await interaction.guild.members.fetch(targetUser.id);
    const botMember = interaction.guild.members.me;
    const executorMember = interaction.member;
    
    // ❌ ПРОВЕРКА: Нельзя выдать роль самому себе
    if (targetUser.id === interaction.user.id) {
        throw createError(
            'Невозможно выдать роль себе',
            ErrorTypes.VALIDATION,
            '❌ Вы не можете выдать роль самому себе. Используйте команду на другого пользователя.',
            { userId: targetUser.id }
        );
    }
    
    // ❌ ПРОВЕРКА: Права бота на ManageRoles
    if (!botMember.permissions.has(PermissionFlagsBits.ManageRoles)) {
        throw createError(
            'У бота нет прав ManageRoles',
            ErrorTypes.PERMISSION,
            '❌ У меня нет права "Управление ролями". Пожалуйста, выдайте мне это право.',
            { missingPermission: 'ManageRoles' }
        );
    }
    
    // ❌ ПРОВЕРКА: У исполнителя есть право выдавать эту роль
    if (!executorMember.permissions.has(PermissionFlagsBits.Administrator)) {
        // Проверяем, может ли исполнитель управлять этой ролью
        if (role.position >= executorMember.roles.highest.position) {
            throw createError(
                'Роль выше вашей',
                ErrorTypes.PERMISSION,
                `❌ Роль "${role.name}" находится выше вашей высшей роли в иерархии. Вы не можете её выдавать.`,
                { rolePosition: role.position, userHighestRole: executorMember.roles.highest.position }
            );
        }
    }
    
    // ❌ ПРОВЕРКА: Роль не выше роли бота
    if (role.position >= botMember.roles.highest.position) {
        throw createError(
            'Роль выше роли бота',
            ErrorTypes.PERMISSION,
            `❌ Роль "${role.name}" находится выше моей высшей роли. Переместите мою роль выше в иерархии сервера.`,
            { botHighestRole: botMember.roles.highest.position, rolePosition: role.position }
        );
    }
    
    // ❌ ПРОВЕРКА: Нельзя выдавать управляемые роли (интеграции, боты)
    if (role.managed) {
        throw createError(
            'Управляемая роль',
            ErrorTypes.VALIDATION,
            `❌ Роль "${role.name}" является управляемой (роль бота или интеграции) и не может быть выдана вручную.`,
            { roleManaged: true }
        );
    }
    
    // ❌ ПРОВЕРКА: Нельзя выдавать @everyone
    if (role.id === interaction.guild.id) {
        throw createError(
            'Роль @everyone',
            ErrorTypes.VALIDATION,
            '❌ Нельзя выдать роль @everyone.',
            {}
        );
    }
    
    // ❌ ПРОВЕРКА: Есть ли уже эта роль у пользователя
    if (targetMember.roles.cache.has(role.id)) {
        throw createError(
            'Роль уже есть',
            ErrorTypes.VALIDATION,
            `❌ У пользователя ${targetUser.toString()} уже есть роль ${role.toString()}.`,
            { roleId: role.id, userId: targetUser.id }
        );
    }
    
    // ✅ ВЫДАЧА РОЛИ
    await targetMember.roles.add(role, `Выдал: ${interaction.user.tag} | Причина: ${reason}`);
    
    // Логирование в канал
    await logToChannel(interaction, {
        action: 'add',
        targetUser,
        role,
        executor: interaction.user,
        reason
    });
    
    // Ответ пользователю
    const embed = successEmbed(
        '✅ Роль выдана',
        `**Пользователь:** ${targetUser.toString()}\n**Роль:** ${role.toString()}\n**Причина:** ${reason}`
    );
    
    await InteractionHelper.safeEditReply(interaction, { embeds: [embed] });
    
    // Логирование в консоль
    logger.info(`[ROLE ADD] ${interaction.user.tag} выдал роль ${role.name} пользователю ${targetUser.tag} | Причина: ${reason}`);
}

// ─────────────────────────────────────────────────────────────────────────────
// СНЯТИЕ РОЛИ
// ─────────────────────────────────────────────────────────────────────────────

async function handleRemoveRole(interaction) {
    const targetUser = interaction.options.getUser('пользователь');
    const role = interaction.options.getRole('роль');
    const reason = interaction.options.getString('причина') || 'Не указана';
    
    const targetMember = await interaction.guild.members.fetch(targetUser.id);
    const botMember = interaction.guild.members.me;
    const executorMember = interaction.member;
    
    // ❌ ПРОВЕРКА: Нельзя снять роль с себя
    if (targetUser.id === interaction.user.id) {
        throw createError(
            'Невозможно снять роль с себя',
            ErrorTypes.VALIDATION,
            '❌ Вы не можете снять роль с самого себя. Используйте команду на другого пользователя.',
            { userId: targetUser.id }
        );
    }
    
    // ❌ ПРОВЕРКА: Права бота
    if (!botMember.permissions.has(PermissionFlagsBits.ManageRoles)) {
        throw createError(
            'У бота нет прав ManageRoles',
            ErrorTypes.PERMISSION,
            '❌ У меня нет права "Управление ролями". Пожалуйста, выдайте мне это право.',
            { missingPermission: 'ManageRoles' }
        );
    }
    
    // ❌ ПРОВЕРКА: Может ли исполнитель управлять этой ролью
    if (!executorMember.permissions.has(PermissionFlagsBits.Administrator)) {
        if (role.position >= executorMember.roles.highest.position) {
            throw createError(
                'Роль выше вашей',
                ErrorTypes.PERMISSION,
                `❌ Роль "${role.name}" находится выше вашей высшей роли. Вы не можете её снимать.`,
                { rolePosition: role.position, userHighestRole: executorMember.roles.highest.position }
            );
        }
    }
    
    // ❌ ПРОВЕРКА: Роль не выше роли бота
    if (role.position >= botMember.roles.highest.position) {
        throw createError(
            'Роль выше роли бота',
            ErrorTypes.PERMISSION,
            `❌ Роль "${role.name}" находится выше моей высшей роли.`,
            { botHighestRole: botMember.roles.highest.position }
        );
    }
    
    // ❌ ПРОВЕРКА: Есть ли у пользователя эта роль
    if (!targetMember.roles.cache.has(role.id)) {
        throw createError(
            'Роль отсутствует',
            ErrorTypes.VALIDATION,
            `❌ У пользователя ${targetUser.toString()} нет роли ${role.toString()}.`,
            { roleId: role.id, userId: targetUser.id }
        );
    }
    
    // ✅ СНЯТИЕ РОЛИ
    await targetMember.roles.remove(role, `Снял: ${interaction.user.tag} | Причина: ${reason}`);
    
    // Логирование в канал
    await logToChannel(interaction, {
        action: 'remove',
        targetUser,
        role,
        executor: interaction.user,
        reason
    });
    
    // Ответ пользователю
    const embed = successEmbed(
        '✅ Роль снята',
        `**Пользователь:** ${targetUser.toString()}\n**Роль:** ${role.toString()}\n**Причина:** ${reason}`
    );
    
    await InteractionHelper.safeEditReply(interaction, { embeds: [embed] });
    
    logger.info(`[ROLE REMOVE] ${interaction.user.tag} снял роль ${role.name} с пользователя ${targetUser.tag} | Причина: ${reason}`);
}

// ─────────────────────────────────────────────────────────────────────────────
// СПИСОК РОЛЕЙ ПОЛЬЗОВАТЕЛЯ
// ─────────────────────────────────────────────────────────────────────────────

async function handleListRoles(interaction) {
    const targetUser = interaction.options.getUser('пользователь');
    const targetMember = await interaction.guild.members.fetch(targetUser.id);
    
    const roles = targetMember.roles.cache
        .filter(role => role.id !== interaction.guild.id) // Убираем @everyone
        .sort((a, b) => b.position - a.position); // Сортируем по позиции (высшие первыми)
    
    if (roles.size === 0) {
        const embed = errorEmbed(
            '📋 Нет ролей',
            `У пользователя ${targetUser.toString()} нет никаких ролей (кроме @everyone).`
        );
        return await InteractionHelper.safeEditReply(interaction, { embeds: [embed] });
    }
    
    const rolesList = roles.map(role => `${role.toString()} — \`${role.id}\``).join('\n');
    
    const embed = {
        color: getColor('info'),
        title: `📋 Роли пользователя ${targetUser.tag}`,
        thumbnail: { url: targetUser.displayAvatarURL() },
        description: rolesList,
        fields: [
            {
                name: '📊 Всего ролей',
                value: `${roles.size}`,
                inline: true
            },
            {
                name: '🎭 Высшая роль',
                value: roles.first()?.toString() || 'Нет',
                inline: true
            }
        ],
        footer: { text: `ID пользователя: ${targetUser.id}` },
        timestamp: new Date()
    };
    
    await InteractionHelper.safeEditReply(interaction, { embeds: [embed] });
}

// ─────────────────────────────────────────────────────────────────────────────
// ЛОГИРОВАНИЕ В СПЕЦИАЛЬНЫЙ КАНАЛ
// ─────────────────────────────────────────────────────────────────────────────

async function logToChannel(interaction, { action, targetUser, role, executor, reason }) {
    // Если канал для логов не указан — пропускаем
    if (!ROLE_LOG_CHANNEL_ID) {
        logger.debug('ROLE_LOG_CHANNEL_ID не указан, логирование в канал пропущено');
        return;
    }
    
    try {
        const logChannel = interaction.guild.channels.cache.get(ROLE_LOG_CHANNEL_ID);
        
        if (!logChannel) {
            logger.warn(`Канал для логов ролей не найден: ${ROLE_LOG_CHANNEL_ID}`);
            return;
        }
        
        // Проверяем, может ли бот писать в этот канал
        if (!logChannel.permissionsFor(interaction.guild.members.me).has(PermissionFlagsBits.SendMessages)) {
            logger.warn(`Нет прав на отправку сообщений в канал логов: ${logChannel.name}`);
            return;
        }
        
        const actionText = action === 'add' ? '🟢 ВЫДАЧА РОЛИ' : '🔴 СНЯТИЕ РОЛИ';
        const actionColor = action === 'add' ? getColor('success') : getColor('error');
        
        const logEmbed = {
            color: actionColor,
            title: actionText,
            thumbnail: { url: targetUser.displayAvatarURL() },
            fields: [
                {
                    name: '👤 Пользователь',
                    value: `${targetUser.toString()} \`${targetUser.tag}\` \`${targetUser.id}\``,
                    inline: false
                },
                {
                    name: '🎭 Роль',
                    value: `${role.toString()} \`${role.name}\` \`${role.id}\``,
                    inline: true
                },
                {
                    name: '⚙️ Выдал/снял',
                    value: `${executor.toString()} \`${executor.tag}\` \`${executor.id}\``,
                    inline: true
                },
                {
                    name: '📝 Причина',
                    value: reason.length > 1024 ? reason.substring(0, 1021) + '...' : reason,
                    inline: false
                },
                {
                    name: '🔗 Действие',
                    value: `[/роли ${action}](https://discord.com/channels/${interaction.guildId}/${interaction.channelId}/${interaction.id})`,
                    inline: true
                }
            ],
            footer: { text: `#${interaction.channel.name}` },
            timestamp: new Date()
        };
        
        await logChannel.send({ embeds: [logEmbed] });
        
    } catch (error) {
        logger.error('Ошибка при отправке лога в канал:', error);
        // Не прерываем выполнение команды из-за ошибки логирования
    }
}
